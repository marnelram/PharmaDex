datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum DosageForm {
  PILL
  POWDER
  INJECTION
  LIQUID
  DROP
  CREAM
  INHALER
  INSERT
  PATCH
  SPRAY
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  passHash      String?
  isAdmin       Boolean   @default(false)
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  topScore      Int       @default(0)
  achievements  UserAchievement[]
  quizAttempts  QuizAttempt[]
  badges        UserBadge[]
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Drug {
  id          String   @id @default(cuid())
  name        String   @unique
  generic     String
  dosageForm  DosageForm
  image       String?
  description String
  drugClass   String
  generation  Int?
  facts       Fact[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pokemon {
  id          String   @id @default(cuid())
  name        String   @unique
  image       String?
  description String
  type1       String
  type2       String?
  generation  Int
  facts       Fact[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Fact {
  id        String    @id @default(cuid())
  title     String
  content   String
  category  String    // e.g., "drug", "pokemon"
  drugId    String?
  drug      Drug?     @relation(fields: [drugId], references: [id])
  pokemonId String?
  pokemon   Pokemon?  @relation(fields: [pokemonId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Achievement {
  id          String            @id @default(cuid())
  name        String            @unique
  description String
  icon        String
  threshold   Int
  category    String
  users       UserAchievement[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model UserAchievement {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  achievementId String
  createdAt     DateTime    @default(now())

  @@unique([userId, achievementId])
}

model QuizAttempt {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  displayName    String?   // optional name for leaderboard
  totalScore     Int
  completed      Boolean   @default(false)
  correctCount   Int       @default(0)
  totalQuestions Int
  answers        Answer[]
  createdAt      DateTime  @default(now())

  @@index([completed(sort: Desc), createdAt(sort: Asc)])
}

model Answer {
  id            String      @id @default(cuid())
  questionName  String      // The name that was guessed
  userGuess     String      // "drug" or "pokemon"
  score         Int
  isCorrect     Boolean
  quizAttempt   QuizAttempt @relation(fields: [quizAttemptId], references: [id])
  quizAttemptId String

  @@index([quizAttemptId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  icon        String?     // Store the icon name as a string
  description String
  total       Int
  color       String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  badge     Badge    @relation(fields: [badgeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
}
