datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.String
  access_token       String? @db.String
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.String
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  score         Int       @default(0)
  achievements  UserAchievement[]
  quizAttempts  QuizAttempt[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Drug {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String
  type        String
  facts       Fact[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pokemon {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String
  type        String   // e.g., "fire", "water", etc.
  facts       Fact[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Fact {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  category  String    // e.g., "drug", "pokemon"
  drugId    String?   @db.ObjectId
  drug      Drug?     @relation(fields: [drugId], references: [id])
  pokemonId String?   @db.ObjectId
  pokemon   Pokemon?  @relation(fields: [pokemonId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Achievement {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  name        String            @unique
  description String
  icon        String
  threshold   Int
  category    String
  users       UserAchievement[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model UserAchievement {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  userId        String      @db.ObjectId
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  achievementId String      @db.ObjectId
  createdAt     DateTime    @default(now())

  @@unique([userId, achievementId])
}

model QuizAttempt {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  user      User      @relation(fields: [userId], references: [id])
  score     Int
  answers   Answer[]  // Track individual answers
  createdAt DateTime  @default(now())
}

model Answer {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  quizAttemptId String      @db.ObjectId
  quizAttempt   QuizAttempt @relation(fields: [quizAttemptId], references: [id])
  questionName  String      // The name that was guessed
  userGuess     String      // "drug" or "pokemon"
  isCorrect     Boolean
  createdAt     DateTime    @default(now())
}
